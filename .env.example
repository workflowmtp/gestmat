# ============================================
# GEST-MAT BTP — Configuration environnement
# ============================================
# Copier ce fichier en .env.local et remplir les valeurs

# --- Base de données PostgreSQL ---
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="postgres"
DB_PASSWORD="password"
DB_NAME="gestmat_btp"
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="changer-cette-valeur-avec-openssl-rand-base64-32"

# --- Agent IA (n8n webhook, Basic Auth) ---
N8N_WEBHOOK_URL="https://votre-instance-n8n.com/webhook/votre-id"
N8N_WEBHOOK_USER="votre-user-basic-auth"
N8N_WEBHOOK_PASSWORD="votre-password-basic-auth"

# --- Application ---
APP_NAME="GEST-MAT BTP"
APP_COMPANY="BTP Solutions Cameroun"
APP_CURRENCY="FCFA"
APP_LOCALE="fr"

# --- Upload photos (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=""

# --- Email notifications (optionnel) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@gestmat-btp.com"
